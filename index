<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The 30-Day Launchpad — Week 1 Student Deck</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:      #FFFFFF;
    --card:       #F4F5F8;
    --card2:      #ECEEF4;
    --border:     #D0D4E0;
    --text:       #111318;
    --muted:      #4A4E63;
    --amber:      #C07800;
    --amber2:     #E09000;
    --teal:       #156F6F;
    --red:        #B83025;
    --green:      #1A7038;
    --nav-bg:     #111318;
    --nav-text:   #F0EDE6;
    --nav-muted:  #8B8FA8;
    --nav-border: #2E3240;
    --accent-bg:  rgba(192,120,0,0.08);
    --teal-bg:    rgba(21,111,111,0.08);
    --green-bg:   rgba(26,112,56,0.08);
    --red-bg:     rgba(184,48,37,0.08);
  }

  html, body {
    height: 100%;
    background: var(--black);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.5;
    overflow: hidden;
  }

  /* ── SLIDE CONTAINER ── */
  #deck {
    width: 100vw;
    height: 100vh;
    position: relative;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 3.5vw 7vw 80px 7vw;
    padding-top: max(3.5vw, 1.5rem);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    overflow-y: auto;
    overflow-x: hidden;
    /* Custom scrollbar — subtle */
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .slide::-webkit-scrollbar { width: 4px; }
  .slide::-webkit-scrollbar-track { background: transparent; }
  .slide::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .slide.active {
    opacity: 1;
    pointer-events: all;
  }

  /* Slides that are mostly one element benefit from vertical centering */
  .slide-title,
  .slide-week-intro,
  .slide-close {
    justify-content: center;
  }

  /* ── NAV BAR — stays dark for contrast ── */
  #nav-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: 56px;
    background: var(--nav-bg);
    border-top: 1px solid var(--nav-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    z-index: 100;
  }
  #week-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: #F5A623;
    text-transform: uppercase;
  }
  #slide-counter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--nav-muted);
  }
  .nav-btn {
    background: none;
    border: 1px solid var(--nav-border);
    color: var(--nav-text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.45rem 1.25rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .nav-btn:hover { background: #F5A623; color: #111318; border-color: #F5A623; }
  .nav-btns { display: flex; gap: 0.5rem; }

  /* progress bar */
  #progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    background: var(--amber);
    transition: width 0.3s ease;
    z-index: 101;
  }

  /* ── WEEK NAV — stays dark ── */
  #week-nav {
    position: fixed;
    top: 1rem; right: 1.5rem;
    display: flex; gap: 0.4rem;
    z-index: 100;
  }
  .wk-btn {
    background: var(--nav-bg);
    border: 1px solid var(--nav-border);
    color: var(--nav-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.1em;
  }
  .wk-btn:hover, .wk-btn.active { background: #F5A623; color: #111318; border-color: #F5A623; }

  /* ── SLIDE TYPES ── */

  /* TITLE SLIDE */
  .slide-title { background: var(--black); }
  .slide-title .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .slide-title h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 2rem;
    color: var(--text);
  }
  .slide-title h1 em { font-style: normal; color: var(--amber); }
  .slide-title .subtitle {
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.25rem);
    max-width: 580px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }
  .stat-row { display: flex; gap: 3rem; }
  .stat .n {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--amber);
  }
  .stat .l {
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* WEEK INTRO SLIDE */
  .slide-week-intro { background: var(--card); }
  .slide-week-intro .big-num {
    font-family: 'Syne', sans-serif;
    font-size: clamp(6rem, 18vw, 16rem);
    font-weight: 800;
    line-height: 0.85;
    color: var(--border);
    position: absolute;
    right: 5vw;
    bottom: 3rem;
  }
  .slide-week-intro .wk-tag {
    display: inline-block;
    background: var(--amber);
    color: #FFFFFF;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 0.3rem 0.85rem;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }
  .slide-week-intro h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    max-width: 60vw;
    position: relative;
    z-index: 1;
    color: var(--text);
  }
  .slide-week-intro .obj {
    color: var(--muted);
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    max-width: 52vw;
    line-height: 1.65;
    position: relative;
    z-index: 1;
  }

  /* VOCAB SLIDE */
  .slide-vocab { background: var(--black); }
  .slide-vocab .slide-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.2vw, 2.5rem);
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .slide-vocab .slide-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--amber);
    letter-spacing: 0.15em;
    margin-bottom: 1.75rem;
    text-transform: uppercase;
  }
  .vocab-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .vl-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.1rem 1.5rem;
    background: var(--card);
    border-left: 4px solid var(--teal);
  }
  .vl-term {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--teal);
    min-width: 160px;
    flex-shrink: 0;
  }
  .vl-def { font-size: 1rem; color: var(--muted); line-height: 1.55; }

  /* CONCEPT / ANALOGY SLIDE */
  .slide-concept { background: var(--card); }
  .slide-concept .concept-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .slide-concept h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
  .concept-box {
    background: var(--black);
    border: 1px solid var(--border);
    border-top: 3px solid var(--amber);
    padding: 1.5rem;
  }
  .concept-box h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--amber);
    margin-bottom: 0.75rem;
  }
  .concept-box p { font-size: 1rem; color: var(--muted); line-height: 1.65; }
  .concept-box .highlight {
    margin-top: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--card);
    padding: 0.7rem 0.85rem;
    border-left: 3px solid var(--teal);
  }

  /* FORMULA SLIDE */
  .slide-formula { background: var(--black); }
  .slide-formula .formula-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .slide-formula h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .formula-big {
    background: var(--card);
    border: 2px solid var(--amber);
    display: inline-block;
    padding: 1.75rem 3rem;
    margin-bottom: 2rem;
  }
  .formula-big .f-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .formula-big .f-eq {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1.1rem, 2.5vw, 1.7rem);
    font-weight: 600;
    color: var(--amber);
    letter-spacing: 0.04em;
  }
  .drill-table-slide {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(0.9rem, 1.5vw, 1rem);
  }
  .drill-table-slide th {
    background: var(--card2);
    padding: 0.75rem 1.1rem;
    text-align: left;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--muted);
    text-transform: uppercase;
    border-bottom: 2px solid var(--border);
  }
  .drill-table-slide td {
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    line-height: 1.45;
  }
  .drill-table-slide tr:last-child td { border-bottom: none; }
  .target-tag {
    display: inline-block;
    background: var(--accent-bg);
    color: var(--amber);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .blank {
    display: inline-block;
    width: 90px;
    border-bottom: 2px solid var(--amber);
    height: 1.2em;
    vertical-align: middle;
  }

  /* QUIZ SLIDE */
  .slide-quiz { background: var(--card); }
  .slide-quiz .quiz-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .quiz-q-big {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 3.2vw, 2.4rem);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 2rem;
    max-width: 78vw;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 72vw;
  }
  .q-opt {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.1rem 1.5rem;
    background: var(--black);
    border: 2px solid var(--border);
    cursor: pointer;
    transition: all 0.2s;
    font-size: clamp(0.95rem, 1.6vw, 1.05rem);
    color: var(--text);
  }
  .q-opt:hover { border-color: var(--amber); background: var(--accent-bg); }
  .q-opt.correct { border-color: var(--green); background: var(--green-bg); }
  .q-opt.wrong { border-color: var(--red); background: var(--red-bg); }
  .opt-letter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--amber);
    min-width: 1.8rem;
    font-weight: 700;
  }
  .quiz-open-answer {
    background: var(--black);
    border: 1px solid var(--border);
    border-left: 4px solid var(--amber);
    padding: 1.5rem 1.75rem;
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    color: var(--muted);
    line-height: 1.65;
    max-width: 68vw;
  }
  .quiz-open-answer .blank-line {
    display: block;
    width: 240px;
    border-bottom: 2px solid var(--amber);
    height: 1.6em;
    margin: 0.6rem 0;
  }

  /* DELTA VISUAL SLIDE */
  .slide-delta { background: var(--black); }
  .delta-visual-row {
    display: flex; align-items: center; gap: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .dv-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.85rem, 1.3vw, 0.95rem);
    color: var(--muted);
    width: 180px;
    flex-shrink: 0;
  }
  .dv-track {
    flex: 1;
    height: clamp(36px, 5vw, 50px);
    background: var(--card);
    position: relative;
    border: 1px solid var(--border);
  }
  .dv-fill {
    height: 100%;
    display: flex; align-items: center;
    padding-left: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.82rem, 1.3vw, 0.95rem);
    font-weight: 600;
    color: #FFFFFF;
  }

  /* RUNBOOK SLIDE */
  .slide-runbook { background: var(--card); }
  .runbook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 1.5rem;
  }
  .rb-step {
    background: var(--black);
    padding: 1.5rem;
  }
  .rb-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--amber);
    letter-spacing: 0.18em;
    margin-bottom: 0.5rem;
  }
  .rb-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .rb-desc { font-size: clamp(0.88rem, 1.3vw, 0.95rem); color: var(--muted); line-height: 1.5; }

  /* CONSTITUTION SLIDE */
  .slide-constitution { background: var(--card); }
  .const-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .const-item {
    border: 1px solid var(--border);
    padding: 1.75rem;
    background: var(--black);
  }
  .const-n {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--amber);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .const-t {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .const-d { font-size: clamp(0.9rem, 1.3vw, 1rem); color: var(--muted); line-height: 1.55; }

  /* ANALOGY SLIDE */
  .slide-analogy { background: var(--black); }
  .analogy-box {
    max-width: 72vw;
    background: var(--card);
    border-left: 5px solid var(--amber);
    padding: 1.75rem 2.25rem;
    margin-bottom: 1.25rem;
    font-size: clamp(1rem, 1.7vw, 1.1rem);
    line-height: 1.75;
    color: var(--text);
  }
  .role-row { display: flex; gap: 1.25rem; margin-top: 0.75rem; }
  .role-box {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1rem 1.25rem;
    flex: 1;
    font-size: clamp(0.9rem, 1.4vw, 1rem);
  }
  .role-box .rl { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; letter-spacing: 0.1em; margin-bottom: 0.35rem; }
  .role-box .buyer-l { color: var(--teal); }
  .role-box .seller-l { color: var(--amber); }
  .role-box .rd { color: var(--muted); }

  /* CLOSING SLIDE */
  .slide-close { background: var(--black); text-align: center; align-items: center; }
  .slide-close .close-quote {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 700;
    font-style: italic;
    color: var(--muted);
    max-width: 680px;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .slide-close .close-attr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--border);
    letter-spacing: 0.12em;
    margin-bottom: 3rem;
  }
  .slide-close .close-cta {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 800;
    color: var(--amber);
    letter-spacing: -0.02em;
  }

  /* ── FOUNDATION SLIDES ── */
  .slide-foundation { background: var(--black); }
  .slide-foundation .f-eyebrow { font-family:'JetBrains Mono',monospace; font-size:0.85rem; letter-spacing:0.18em; color:var(--teal); text-transform:uppercase; margin-bottom:1rem; }
  .slide-foundation h2 { font-family:'Syne',sans-serif; font-size:clamp(1.7rem,3.2vw,2.6rem); font-weight:800; letter-spacing:-0.02em; margin-bottom:1.5rem; color:var(--text); }
  .foundation-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; max-width:80vw; }
  .f-box { background:var(--card); border:1px solid var(--border); border-top:4px solid var(--teal); padding:1.35rem 1.5rem; }
  .f-box.amber { border-top-color:var(--amber); }
  .f-box h3 { font-family:'Syne',sans-serif; font-weight:700; font-size:clamp(0.95rem,1.5vw,1.1rem); color:var(--teal); margin-bottom:0.6rem; }
  .f-box.amber h3 { color:var(--amber); }
  .f-box p { font-size:clamp(0.9rem,1.4vw,1rem); color:var(--muted); line-height:1.6; }
  .f-box .f-example { margin-top:0.75rem; padding:0.65rem 0.85rem; background:var(--black); border-left:3px solid var(--teal); font-family:'JetBrains Mono',monospace; font-size:0.85rem; color:var(--amber); }
  .f-box.amber .f-example { border-left-color:var(--amber); }
  .full-box { grid-column:1/-1; background:var(--card2); border:1px solid var(--border); padding:1.35rem 1.5rem; }
  .full-box p { font-size:clamp(0.95rem,1.4vw,1.05rem); color:var(--muted); line-height:1.65; }

  /* ── SOFI SLIDE ── */
  .slide-sofi { background: var(--card); }
  .slide-sofi .s-eyebrow { font-family:'JetBrains Mono',monospace; font-size:0.85rem; letter-spacing:0.18em; color:var(--amber); text-transform:uppercase; margin-bottom:1rem; }
  .slide-sofi h2 { font-family:'Syne',sans-serif; font-size:clamp(1.7rem,3.2vw,2.5rem); font-weight:800; letter-spacing:-0.02em; margin-bottom:1.25rem; color:var(--text); }
  .sofi-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--border); border:1px solid var(--border); max-width:82vw; margin-bottom:1.25rem; }
  .sofi-cell { background:var(--black); padding:1.1rem 1.35rem; }
  .sofi-cell .sc-label { font-family:'JetBrains Mono',monospace; font-size:0.78rem; letter-spacing:0.12em; color:var(--muted); text-transform:uppercase; margin-bottom:0.35rem; }
  .sofi-cell .sc-val { font-family:'Syne',sans-serif; font-weight:700; font-size:clamp(1rem,1.6vw,1.2rem); color:var(--amber); }
  .sofi-cell .sc-sub { font-size:0.88rem; color:var(--muted); margin-top:0.2rem; }
  .sofi-why { max-width:82vw; display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .sofi-reason { background:var(--black); border-left:4px solid var(--teal); padding:1rem 1.1rem; font-size:clamp(0.9rem,1.3vw,1rem); color:var(--muted); line-height:1.55; }
  .sofi-reason strong { color:var(--text); }

  /* ── INSPIRATION SLIDES ── */
