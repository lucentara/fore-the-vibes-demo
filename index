<script>
  const slides = Array.from(document.querySelectorAll('.slide'));
  const total = slides.length;
  let current = 0;

  function show(idx) {
    slides[current].classList.remove('active');
    current = Math.max(0, Math.min(total - 1, idx));
    slides[current].classList.add('active');
    slides[current].scrollTop = 0;
    document.getElementById('progress').style.width = ((current / (total - 1)) * 100) + '%';
    document.getElementById('slide-counter').textContent = (current + 1) + ' / ' + total;
  }

  function nextSlide() { show(current + 1); }
  function prevSlide() { show(current - 1); }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') nextSlide();
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   prevSlide();
  });

  document.getElementById('deck').addEventListener('click', e => {
    if (!e.target.closest('.q-opt') && !e.target.closest('.act-opt') && !e.target.closest('.reveal-btn') && !e.target.closest('#nav-bar')) {
      // Only advance if the active slide is not scrollable or is already at the bottom
      const active = slides[current];
      const atBottom = active.scrollHeight - active.scrollTop <= active.clientHeight + 10;
      if (active.scrollHeight <= active.clientHeight + 10 || atBottom) {
        nextSlide();
      }
    }
  });

  document.querySelectorAll('.q-opt').forEach(opt => {
    opt.addEventListener('click', e => {
      e.stopPropagation();
      const siblings = opt.parentElement.querySelectorAll('.q-opt');
      siblings.forEach(s => s.classList.remove('correct', 'wrong'));
      opt.classList.add('correct');
    });
  });

  function selectAct(el, groupId) {
    document.querySelectorAll('#' + groupId + ' .act-opt').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
  }

  function revealAct(revealId) {
    const el = document.getElementById(revealId);
    if (el) {
      el.classList.toggle('show');
      const btn = el.previousElementSibling;
      if (btn && btn.classList.contains('reveal-btn')) {
        btn.textContent = el.classList.contains('show') ? 'Hide Answer' : 'Reveal Answer';
      }
    }
  }

  show(0);
</script>
